{
  "id": "trans-paper",
  "name": "论文翻译服务",
  "category": "工具类",
  "type": "service",
  "status": "draft",
  "summary": "把 pdf2zh-next 包成可启动的论文翻译服务。",
  "description": "这是一个工具服务项目。现在已经接入 dashboard，可以做配置检查、启动和停止。第一次使用前，要先运行 setup.bat 填好 API Key。",
  "path": "E:/Project/codex/TransPaper",
  "entry": "http://127.0.0.1:7862/",
  "health": "http://127.0.0.1:7862/",
  "integration": "project-config",
  "control": {
    "enabled": true,
    "type": "service",
    "actions": ["test", "run", "stop"],
    "testCommand": {
      "command": "powershell",
      "args": ["-NoProfile", "-NonInteractive", "-WindowStyle", "Hidden", "-ExecutionPolicy", "Bypass", "-File", "scripts/test.ps1"]
    },
    "runCommand": {
      "command": "powershell",
      "args": ["-NoProfile", "-NonInteractive", "-WindowStyle", "Hidden", "-ExecutionPolicy", "Bypass", "-File", "scripts/run.ps1"]
    },
    "stopCommand": {
      "command": "powershell",
      "args": ["-NoProfile", "-NonInteractive", "-WindowStyle", "Hidden", "-ExecutionPolicy", "Bypass", "-File", "scripts/stop.ps1"]
    },
    "processMatch": {
      "name": "python.exe",
      "commandLinePattern": "*TransPaper*start_server.py*"
    },
    "startupProbe": {
      "initialDelayMs": 5000,
      "attempts": 40,
      "intervalMs": 3000
    }
  },
  "paths": {
    "config": "config",
    "logs": "logs"
  },
  "timeline": [
    {
      "time": "今天",
      "title": "接入真实控制层",
      "note": "dashboard 现在可以检查配置、启动和停止这个项目。"
    }
  ]
}
